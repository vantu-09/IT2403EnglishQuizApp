         </children>
      </HBox>
      <VBox fx:id="vChoices" prefHeight="121.0" prefWidth="580.0">
         <children>
            <HBox prefHeight="42.0" prefWidth="580.0" styleClass="Container">
               <children>
                  <RadioButton mnemonicParsing="false">
                     <toggleGroup>
                        <ToggleGroup fx:id="toggle" />
                     </toggleGroup></RadioButton>
                  <TextField styleClass="Input" />
               </children>
            </HBox>
            <HBox layoutX="10.0" layoutY="10.0" prefHeight="41.0" prefWidth="580.0" styleClass="Container">
